    {
      reply_markup: {
        inline_keyboard: [
          [{ text: 'рҹ§‘вҖҚрҹ’» бҙ„бҙҸЙҙбҙӣбҙҖбҙ„бҙӣ бҙҸбҙЎЙҙбҙҮКҖ', url: SOCIAL_LINKS.developer }]
